{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",

  "logo": {
    "source": "auto",
    "padding": {
      "right": 5
    }
  },

  "display": {
    "separator": " ➜ "
  },

  "modules": [
    "title",
    "break",

    {
      "type": "os",
      "key": "󰣇  OS"
    },
    {
      "type": "host",
      "key": "󰌢  Host"
    },
    {
      "type": "kernel",
      "key": "󰒋  Kernel"
    },
    {
      "type": "uptime",
      "key": "󰅐  Uptime"
    },

    "break",

    {
      "type": "cpu",
      "key": "󰍛  CPU"
    },
    {
      "type": "gpu",
      "key": "󰢮  GPU"
    },
    {
      "type": "memory",
      "key": "󰑭  Memory"
    },
    {
      "type": "disk",
      "key": "󰋊  Root"
    },
    {
      "type": "disk",
      "folders": "/home",
      "key": "󰋊  Home"
    },

    "break",

    {
      "type": "packages",
      "key": "󰏖  Packages"
    },
    {
      "type": "shell",
      "key": "󰆍  Shell"
    },
    {
      "type": "terminal",
      "key": "󰞷  Terminal"
    },
    {
      "type": "wm",
      "key": "  WM"
    },
    {
      "type": "de",
      "key": "󰧨  DE"
    },

    "break",

    {
      "type": "localip",
      "key": "󰩠  Local IP"
    },
    {
      "type": "battery",
      "key": "󰁹  Battery"
    },
    {
      "type": "locale",
      "key": "󰌽  Locale"
    },

    "break",
    "colors"
  ]
}
